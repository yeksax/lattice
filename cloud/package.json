{
  "name": "lattice-share",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker backend for lattice hosted shares (snapshots + polls)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:init": "wrangler d1 execute lattice --file schema.sql",
    "db:init:remote": "wrangler d1 execute lattice --remote --file schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "typescript": "^5.6.0",
    "wrangler": "^4.111.0"
  }
}
