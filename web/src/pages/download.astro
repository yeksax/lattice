---
import Layout from '../layouts/Layout.astro';

const github = 'https://github.com/yeksax/lattice';
const releaseBase = `${github}/releases/download/continuous`;
const skillBase = 'https://raw.githubusercontent.com/yeksax/lattice/main/skills/html-summary';

const cliBuilds = [
  { os: 'macos', label: 'macOS · Apple Silicon', file: 'lattice-darwin-arm64' },
  { os: 'macos', label: 'macOS · Intel', file: 'lattice-darwin-amd64' },
  { os: 'linux', label: 'Linux · arm64', file: 'lattice-linux-arm64' },
  { os: 'linux', label: 'Linux · x86-64', file: 'lattice-linux-amd64' },
  { os: 'windows', label: 'Windows · x86-64', file: 'lattice-windows-amd64.exe' },
];
---

<Layout
  title="Download Lattice"
  description="Download the Lattice CLI for macOS, Linux, or Windows, verify its SHA-256 checksum, install the standalone report skill, or add the macOS desktop companion."
  solidHeader
  localize
>
  <!-- ============ intro ============ -->
  <section class="pt-40 pb-16">
    <div class="wrap">
      <p class="eyebrow reveal">download</p>
      <h1
        class="reveal mt-5 font-serif text-ink"
        style="--d: 0.06s; font-size: clamp(2.6rem, 5vw, 4rem); line-height: 1.05; letter-spacing: -0.02em; font-variation-settings: 'opsz' 144; font-weight: 440;"
      >
        Run Lattice on your machine.
      </h1>
      <p id="download-detect" class="lede reveal mt-5" style="--d: 0.12s">Checking your system…</p>
      <p class="reveal mt-3 font-mono text-xs text-muted" style="--d: 0.16s">
        CLI, local daemon, and dashboard in one binary&ensp;·&ensp;MIT licensed
      </p>
    </div>
  </section>

  <!-- ============ cli ============ -->
  <section id="cli" class="section border-t border-line">
    <div class="wrap">
      <p class="eyebrow reveal"><span class="idx">01</span>choose a build</p>
      <h2 class="h-display reveal mt-5" style="--d: 0.06s">One binary for the local workflow.</h2>
      <p class="lede reveal mt-6" style="--d: 0.12s">
        Every push to <code class="font-mono text-[0.92em] text-ink">main</code> publishes five builds to the
        <a href={`${github}/releases/tag/continuous`} class="text-ink underline underline-offset-4" rel="noopener">continuous release</a>.
        Run any Lattice command and the local service starts on demand.
      </p>

      <div class="reveal mt-12" style="--d: 0.16s">
        <div data-when-os="macos">
          <div class="cmdblock">
            <div class="cmdblock-head">
              <span>macOS default · Apple Silicon</span>
              <button class="copy-btn" data-copy-target="#cli-macos" type="button"><span data-copy-label>Copy</span></button>
            </div>
            <pre class="cmdblock-body"><code id="cli-macos">curl -fsSL {releaseBase}/lattice-darwin-arm64 \
  -o /usr/local/bin/lattice &amp;&amp; chmod +x /usr/local/bin/lattice</code></pre>
          </div>
          <p class="mt-3 font-mono text-xs text-muted">
            Using an Intel Mac? Choose <code>lattice-darwin-amd64</code> below.
          </p>
        </div>

        <div data-when-os="linux">
          <div class="cmdblock">
            <div class="cmdblock-head">
              <span>Linux default · x86-64</span>
              <button class="copy-btn" data-copy-target="#cli-linux" type="button"><span data-copy-label>Copy</span></button>
            </div>
            <pre class="cmdblock-body"><code id="cli-linux">curl -fsSL {releaseBase}/lattice-linux-amd64 \
  -o /usr/local/bin/lattice &amp;&amp; chmod +x /usr/local/bin/lattice</code></pre>
          </div>
          <p class="mt-3 font-mono text-xs text-muted">
            Writing to <code>/usr/local/bin</code> may require <code>sudo</code>. The arm64 build is below.
          </p>
        </div>

        <div data-when-os="windows">
          <div class="cmdblock">
            <div class="cmdblock-head">
              <span>Windows · PowerShell</span>
              <button class="copy-btn" data-copy-target="#cli-windows" type="button"><span data-copy-label>Copy</span></button>
            </div>
            <pre class="cmdblock-body"><code id="cli-windows">irm {releaseBase}/lattice-windows-amd64.exe -OutFile lattice.exe</code></pre>
          </div>
          <p class="mt-3 font-mono text-xs text-muted">
            Move <code>lattice.exe</code> into a directory on your <code>PATH</code>.
          </p>
        </div>

        <div data-when-os="unknown">
          <p class="font-mono text-[13px] text-ink2">Choose your platform from the builds below.</p>
        </div>
      </div>

      <div class="download-table reveal mt-10" style="--d: 0.2s">
        {
          cliBuilds.map((build) => (
            <div class="os-row" data-os-row={build.os}>
              <div class="flex flex-wrap items-center justify-between gap-x-6 gap-y-2 px-5 py-4 font-mono text-[13px]">
                <span class="flex items-center gap-3 text-ink">
                  {build.file}
                  <span class="detected-tag rounded-full border border-ink px-2 py-0.5 text-[10px] text-ink">
                    matching OS
                  </span>
                </span>
                <span class="flex items-center gap-6">
                  <span class="text-muted">{build.label}</span>
                  <a href={`${releaseBase}/${build.file}`} class="text-ink2 underline underline-offset-4 transition-colors hover:text-ink">
                    Download
                  </a>
                </span>
              </div>
            </div>
          ))
        }
      </div>
      <p class="reveal mt-4 font-mono text-xs text-muted" style="--d: 0.22s">
        Rename the download to <code>lattice</code> and place it on your <code>PATH</code>. You are ready.
      </p>
    </div>
  </section>

  <!-- ============ verify ============ -->
  <section id="verify" class="section border-t border-line">
    <div class="wrap">
      <p class="eyebrow reveal"><span class="idx">02</span>verify the download</p>
      <h2 class="h-display reveal mt-5" style="--d: 0.06s">Check the file before you run it.</h2>
      <p class="lede reveal mt-6" style="--d: 0.12s">
        Each release includes
        <a href={`${releaseBase}/SHA256SUMS.txt`} class="font-mono text-[0.92em] text-ink underline underline-offset-4" rel="noopener">SHA256SUMS.txt</a>
        beside the binaries. Download the checksum file from the same release, then run the matching
        command in the directory that contains your binary.
      </p>

      <div class="reveal mt-12 grid grid-cols-1 gap-6 lg:grid-cols-2" style="--d: 0.16s">
        <div class="cmdblock">
          <div class="cmdblock-head">
            <span>macOS / Linux</span>
            <button class="copy-btn" data-copy-target="#verify-unix" type="button"><span data-copy-label>Copy</span></button>
          </div>
          <pre class="cmdblock-body"><code id="verify-unix">curl -fsSLO {releaseBase}/SHA256SUMS.txt
shasum -a 256 --check --ignore-missing SHA256SUMS.txt</code></pre>
        </div>
        <div class="cmdblock">
          <div class="cmdblock-head">
            <span>Windows (PowerShell)</span>
            <button class="copy-btn" data-copy-target="#verify-win" type="button"><span data-copy-label>Copy</span></button>
          </div>
          <pre class="cmdblock-body"><code id="verify-win">certutil -hashfile lattice-windows-amd64.exe SHA256
<span class="cm"># compare with the matching line in SHA256SUMS.txt</span></code></pre>
        </div>
      </div>
      <p class="mt-3 font-mono text-xs text-muted">
        On Linux, <code>sha256sum --check --ignore-missing SHA256SUMS.txt</code> works too.
      </p>
    </div>
  </section>

  <!-- ============ the skill ============ -->
  <section id="skill" class="section border-t border-line">
    <div class="wrap grid grid-cols-1 items-start gap-14 lg:grid-cols-[minmax(0,5fr)_minmax(0,6fr)]">
      <div>
        <p class="eyebrow reveal"><span class="idx">03</span>the report skill</p>
        <h2 class="h-display reveal mt-5" style="--d: 0.06s">Want the format without the library?</h2>
        <div class="prose-plain reveal mt-8" style="--d: 0.12s">
          <p>
            Install two files that teach compatible agents to create concise, self-contained HTML
            reports. The skill works on its own, with no daemon or CLI.
          </p>
          <p>
            <a
              href={`${github}/blob/main/skills/html-summary/SKILL.md`}
              class="font-mono text-[13px] text-ink2 underline underline-offset-4 transition-colors hover:text-ink"
              rel="noopener"
            >
              Inspect the skill
            </a>
          </p>
        </div>
      </div>
      <div class="reveal" style="--d: 0.14s">
        <div class="cmdblock">
          <div class="cmdblock-head">
            <span>html-summary · standalone</span>
            <button class="copy-btn" data-copy-target="#skill-only-code" type="button"><span data-copy-label>Copy</span></button>
          </div>
          <pre class="cmdblock-body"><code id="skill-only-code">mkdir -p ~/.claude/skills/html-summary
curl -fsSL {skillBase}/SKILL.md \
  -o ~/.claude/skills/html-summary/SKILL.md
curl -fsSL {skillBase}/template.html \
  -o ~/.claude/skills/html-summary/template.html</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ desktop ============ -->
  <section id="desktop" class="section border-t border-line">
    <div class="wrap grid grid-cols-1 items-start gap-14 lg:grid-cols-[minmax(0,5fr)_minmax(0,6fr)]">
      <div>
        <p class="eyebrow reveal"><span class="idx">04</span>macOS companion</p>
        <h2 class="h-display reveal mt-5" style="--d: 0.06s">Add Lattice to the menu bar.</h2>
        <p class="prose-plain reveal mt-8" style="--d: 0.12s">
          The desktop app is an optional control surface for the local service. The CLI remains the
          complete product; the app adds quick access on Apple Silicon and Intel Macs.
        </p>
      </div>
      <div class="surface-card reveal p-8" style="--d: 0.14s">
        <div data-os-app="available">
          <p class="font-mono text-[13px] text-ink">Lattice.dmg · universal</p>
          <a class="btn btn-ghost mt-6" href={`${releaseBase}/Lattice.dmg`}>
            Download for macOS
            <svg class="h-[13px] w-[13px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="12" x2="20" y2="12" /><polyline points="14 6 20 12 14 18" /></svg>
          </a>
        </div>
        <div data-os-app="soon" hidden>
          <p class="font-mono text-[13px] text-ink">The desktop companion is macOS only</p>
          <p class="mt-3 text-sm text-ink2">
            Use the CLI above for the complete Lattice workflow.
            <a href={`${releaseBase}/Lattice.dmg`} class="text-ink underline underline-offset-4">Lattice.dmg</a>
            is available if you also use a Mac.
          </p>
        </div>
        <p class="mt-6 font-mono text-xs text-muted">
          Unsigned development build · use right-click → Open on first launch.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ source ============ -->
  <section id="source" class="section border-t border-line">
    <div class="wrap grid grid-cols-1 items-start gap-14 lg:grid-cols-[minmax(0,5fr)_minmax(0,6fr)]">
      <div>
        <p class="eyebrow reveal"><span class="idx">05</span>build from source</p>
        <h2 class="h-display reveal mt-5" style="--d: 0.06s">Prefer to compile it yourself?</h2>
        <p class="prose-plain reveal mt-8" style="--d: 0.12s">
          Lattice is a single Go module. Clone the repository and build the CLI directly.
        </p>
      </div>
      <div class="reveal" style="--d: 0.14s">
        <div class="cmdblock">
          <div class="cmdblock-head">
            <span>requires Go · builds locally</span>
            <button class="copy-btn" data-copy-target="#source-code" type="button"><span data-copy-label>Copy</span></button>
          </div>
          <pre class="cmdblock-body"><code id="source-code">git clone https://github.com/yeksax/lattice.git
cd lattice
go build -o lattice ./cmd/lattice</code></pre>
        </div>
        <p class="mt-4 font-mono text-[13px]">
          <a href={`${github}/releases/tag/continuous`} class="text-ink2 underline underline-offset-4 transition-colors hover:text-ink" rel="noopener">
            Browse every published build on GitHub Releases
          </a>
        </p>
      </div>
    </div>
  </section>
</Layout>
